{
  "$schema": "./schemas/tsconfig.schema.json",
  "compilerOptions": {
    "outDir": "./lib",
    "rootDir": "./src",
    "module": "commonjs",
    "target": "es2016",
    "lib": ["es2016", "dom"],
    "sourceMap": true,
    "allowJs": false,
    "jsx": "react",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "useDefineForClassFields": false,
    "noImplicitAny": true,
    "types": [
      "node",
      "jest"
    ],
    "baseUrl": ".",
    "paths": {
      "@jupyterlab/*": ["node_modules/@jupyterlab/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules", 
    "**/*.test.ts",
    "src/services/OllamaHealthService.ts",
    "src/utils/performanceUtils.ts"
  ]
}